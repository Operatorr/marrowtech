---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Hero from '../components/marrow/Hero.astro';
import Projects from '../components/marrow/Projects.astro';
import JournalSection from '../components/marrow/JournalSection.astro';
import About from '../components/marrow/About.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Base>
  <Hero />
  <Projects />
  <JournalSection posts={posts} />
  <About />
</Base>
