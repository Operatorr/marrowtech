---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SectionMarker from '../../components/marrow/SectionMarker.astro';
import PostCard from '../../components/marrow/PostCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const description = 'Notes on what I build — engineering, tooling and the occasional teardown.';
---

<Base title="Journal — marrowtech" description={description}>
  <div class="hub-page">
    <div class="hub-page-head">
      <SectionMarker label="Journal" kana="日誌" tone="violet" />
      <h1 class="hub-page-title">Writing & field notes.</h1>
      <p class="hub-page-lead">{description}</p>
    </div>

    <div class="hub-blog-grid">
      {
        posts.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id}/`}
            pubDate={post.data.pubDate}
            tone={i % 2 === 0 ? 'blue' : 'violet'}
            feature={i === 0}
          />
        ))
      }
    </div>
  </div>
</Base>
